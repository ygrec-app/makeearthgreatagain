---
import "../styles/global.css";
import "../styles/tokens.css";

interface Props {
  title?: string;
  description?: string;
}
const { title, description } = Astro.props;
const lang = (Astro.currentLocale ?? "en") as "en" | "fr";
const pageTitle = title ?? "MEGA — Make Earth Great Again";
const pageDesc = description ?? "Nonprofit initiative accelerating resource-conscious technologies.";

// Canonical + hreflang. Astro.site is set in astro.config.mjs.
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const altPath = lang === "en" ? "/fr/" : "/";
const altHref = new URL(altPath, Astro.site).toString();
const ogImage = new URL("/og.png", Astro.site).toString();
const ogLocale = lang === "fr" ? "fr_FR" : "en_US";
const ogLocaleAlt = lang === "fr" ? "en_US" : "fr_FR";
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={pageDesc} />
    <title>{pageTitle}</title>

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={lang === "en" ? "fr" : "en"} href={altHref} />
    <link rel="alternate" hreflang="x-default" href={new URL("/", Astro.site).toString()} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#4048F3" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MEGA" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
  </head>
  <body data-mode="light">
    <slot />
    <script>
      import Lenis from "lenis";
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);

      const lenis = new Lenis({ smoothWheel: true });
      lenis.on("scroll", ScrollTrigger.update);
      gsap.ticker.add((t) => lenis.raf(t * 1000));
      gsap.ticker.lagSmoothing(0);

      // Mode persistence — toggle component (Worker B) writes to localStorage["mega:mode"]
      const stored = localStorage.getItem("mega:mode");
      const prefersDark = matchMedia("(prefers-color-scheme: dark)").matches;
      const initial = stored ?? (prefersDark ? "drenched" : "light");
      document.body.dataset.mode = initial;

      // Expose lenis on window for cross-island access (overlay open/close,
      // anchor scrolls, etc.)
      (window as any).__lenis = lenis;
    </script>
  </body>
</html>
